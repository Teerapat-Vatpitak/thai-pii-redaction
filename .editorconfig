# Editor defaults shared across the repo. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{js,json,jsonc,css,html,yml,yaml,toml,md}]
indent_size = 2

[*.{ps1,bat}]
end_of_line = crlf

[*.md]
# Markdown uses trailing double-space for hard line breaks.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
