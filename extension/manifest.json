{
  "manifest_version": 3,
  "name": "AI Guard - Thai PII Mask",
  "version": "2.2.0",
  "description": "Mask Thai PII before sending to ChatGPT, Claude, Gemini, Grok, Perplexity, or GLM/Z.ai, then restore it locally from the AI reply. PSU FTC 2026.",
  "action": {
    "default_title": "เปิดแถบ AI Guard",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "clipboardWrite", "sidePanel"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://*.grok.com/*",
        "https://perplexity.ai/*",
        "https://*.perplexity.ai/*",
        "https://chat.z.ai/*",
        "https://*.z.ai/*",
        "https://chatglm.cn/*",
        "https://*.chatglm.cn/*",
        "https://*.bigmodel.cn/*"
      ],
      "js": ["sites.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/icon16.png", "icons/icon32.png", "icons/icon48.png", "icons/icon128.png"],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://*.grok.com/*",
        "https://perplexity.ai/*",
        "https://*.perplexity.ai/*",
        "https://chat.z.ai/*",
        "https://*.z.ai/*",
        "https://chatglm.cn/*",
        "https://*.chatglm.cn/*",
        "https://*.bigmodel.cn/*"
      ]
    }
  ]
}
