{
  "name": "aiguard-office-addin",
  "version": "2.4.1",
  "private": true,
  "description": "AI Guard for Microsoft 365 local-first Office Add-in",
  "type": "module",
  "engines": {
    "node": ">=22.12 <23"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "validate:manifest": "node scripts/validate-manifest.mjs",
    "validate:manifest:upstream": "office-addin-manifest validate manifest.json",
    "validate:manifest:local": "office-addin-manifest validate manifest.dev.xml && office-addin-manifest validate manifest.dev.excel.xml && office-addin-manifest validate manifest.dev.powerpoint.xml",
    "start:word": "office-addin-debugging start manifest.json desktop --app word --dev-server-port 3000 --no-debug",
    "start:word:local": "office-addin-debugging start manifest.dev.xml desktop --app word --dev-server-port 3000 --no-debug",
    "start:excel:local": "office-addin-debugging start manifest.dev.excel.xml desktop --app excel --dev-server-port 3000 --no-debug",
    "start:powerpoint:local": "office-addin-debugging start manifest.dev.powerpoint.xml desktop --app powerpoint --dev-server-port 3000 --no-debug",
    "stop": "office-addin-debugging stop manifest.json",
    "stop:local": "office-addin-debugging stop manifest.dev.xml",
    "stop:excel:local": "office-addin-debugging stop manifest.dev.excel.xml",
    "stop:powerpoint:local": "office-addin-debugging stop manifest.dev.powerpoint.xml"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/office-js": "1.0.600",
    "@types/node": "22.20.1",
    "@vitest/coverage-v8": "4.1.10",
    "jsdom": "27.0.0",
    "office-addin-debugging": "6.1.2",
    "office-addin-dev-certs": "2.0.10",
    "office-addin-manifest": "2.1.6",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
