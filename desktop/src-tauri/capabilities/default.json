{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "tray:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/aiguard", "sidecar": true, "args": true }]
    }
  ]
}
